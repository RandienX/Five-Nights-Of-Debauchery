code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool is_flashing = true;
uniform vec4 FlashColor : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform float FlashSpeed : hint_range(0.0, 5.0) = 1.0;
uniform float FlashIntensity : hint_range(0.20000000298023, 4.0) = 1.0;



void fragment() {
// BooleanParameter:13
	bool n_out13p0 = is_flashing;


// ColorConstant:9
	vec4 n_out9p0 = vec4(1.000000, 1.000000, 1.000000, 0.000000);


// Input:16
	vec4 n_out16p0 = COLOR;


	bool n_out10p0;
// Compare:10
	{
		bvec4 _bv = notEqual(n_out9p0, n_out16p0);
		n_out10p0 = any(_bv);
	}


// ColorParameter:15
	vec4 n_out15p0 = FlashColor;


// Input:17
	float n_out17p0 = TIME;


// FloatParameter:3
	float n_out3p0 = FlashSpeed;


// FloatOp:4
	float n_out4p0 = n_out17p0 * n_out3p0;


// FloatFunc:2
	float n_out2p0 = sin(n_out4p0);


// FloatParameter:7
	float n_out7p0 = FlashIntensity;


// FloatOp:8
	float n_in8p0 = 5.00000;
	float n_out8p0 = n_in8p0 - n_out7p0;


// FloatOp:6
	float n_out6p0 = n_out2p0 / n_out8p0;


// FloatFunc:5
	float n_out5p0 = abs(n_out6p0);


// VectorOp:22
	vec3 n_out22p0 = vec3(n_out15p0.xyz) * vec3(n_out5p0);


	vec3 n_out11p0;
// If:11
	float n_in11p1 = 1.00000;
	float n_in11p2 = 0.00001;
	vec3 n_in11p4 = vec3(0.00000, 0.00000, 0.00000);
	vec3 n_in11p5 = vec3(0.00000, 0.00000, 0.00000);
	if(abs((n_out10p0 ? 1.0 : 0.0) - n_in11p1) < n_in11p2)
	{
		n_out11p0 = n_out22p0;
	}
	else if((n_out10p0 ? 1.0 : 0.0) < n_in11p1)
	{
		n_out11p0 = n_in11p5;
	}
	else
	{
		n_out11p0 = n_in11p4;
	}


// Input:20
	vec4 n_out20p0 = COLOR;


// VectorOp:21
	vec3 n_out21p0 = n_out11p0 + vec3(n_out20p0.xyz);


	vec3 n_out14p0;
// If:14
	float n_in14p1 = 1.00000;
	float n_in14p2 = 0.00001;
	if(abs((n_out13p0 ? 1.0 : 0.0) - n_in14p1) < n_in14p2)
	{
		n_out14p0 = n_out21p0;
	}
	else if((n_out13p0 ? 1.0 : 0.0) < n_in14p1)
	{
		n_out14p0 = vec3(n_out20p0.xyz);
	}
	else
	{
		n_out14p0 = vec3(n_out20p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out14p0;


}
